node_modules
dist/
# .opencode runtime state (per-machine, not tracked) — but .opencode/skills/ IS tracked
.opencode/reviews/
.opencode/logs/
.opencode/cache/
.opencode/state.json
.opencode/magic-context/
.opencode/command/
.cortexkit/
.playwright-mcp/
# We use opencode, not Claude CLI — `playwright-cli install --skills` would
# otherwise pollute the project with .claude/skills/. Global install is enough.
.claude/
*.tmp
# .omo/ project-level design library IS tracked (.omo/round-N/, .omo/proposals.jsonl,
# .omo/round-2-plan.md, etc.). Runtime/ephemeral subdirs from other skills stay ignored:
.omo/boulder.json
.omo/drafts/
.omo/evidence/
# .omo/plans/ is the ulw-plan intermediate output — canonical plan lives at .omo/round-N/plan.md
.omo/plans/
.omo/run-continuation/
.omo/start-work/
.omo/state/
# Test artifacts and screenshots are ephemeral; regenerate via e2e tests
scripts/test-review-ui/*.png
scripts/test-review-ui/*-mock.json

# playwright-cli local state (created on first playwright-cli open)
.playwright-cli/
